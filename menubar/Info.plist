<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleExecutable</key>
	<string>Tailmon</string>
	<key>CFBundleIdentifier</key>
	<string>com.bosphorify.tailmon.menubar</string>
	<key>CFBundleName</key>
	<string>Tailmon</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.2.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Agents speak plain HTTP on Tailscale IPs (100.64/10); the tailnet
		     itself is the encrypted transport. ATS only exempts localhost by
		     default, which made peer /health probes fail (-1022). -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>LSUIElement</key>
	<true/>
	<key>NSHighResolutionCapable</key>
	<true/>
</dict>
</plist>
