    <!-- App Transport Security: the collector lives on a Tailscale CGNAT
         IP (100.64.0.0/10) and speaks plain HTTP because the traffic
         already rides on the WireGuard tunnel. macOS blocks HTTP URLSession
         requests by default; NSAllowsArbitraryLoads=YES opts out globally
         for this app. Acceptable for a personal tool that only talks to
         one host on a private overlay network. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>
